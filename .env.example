# ─────────────────────────────────────────────────────────────────────────────
# Abarrotes Suite Nentria — Variables de entorno
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas .env a git.
# ─────────────────────────────────────────────────────────────────────────────


# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini


# ── Base de datos SQL Server ──────────────────────────────────────────────────
# Docker local (desarrollo):
#   DB_HOST=127.0.0.1  DB_PORT=1433
#
# Servidor del cliente (producción):
#   DB_HOST=192.168.1.100  DB_PORT=1433
#
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ERP
DB_USER=sa
DB_PASSWORD=


# ── Puertos de los módulos ────────────────────────────────────────────────────
PWA_PORT=8001
STUDIO_PORT=8002
